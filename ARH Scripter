  local addr = getAddr()
  if not addr then return end

  if caller == "free" and maxAmount > 500 then
    maxAmount = 500
  end

  local prompt = gg.prompt({emoji .. " " .. _(promptKey) .. " [1вҖ“" .. maxAmount .. "]:"}, nil, {"number"})
local amt = tonumber(prompt and prompt[1])

-- вқҢ Tidak memasukkan angka
if not amt then
  return
end

-- вқҢ Melebihi batas 1вҖ“maxAmount
if amt < 1 or amt > maxAmount then
  gg.alert(_("invalid_range_kuponpon") .. "\nвң… Min: 1\nвң… Max: " .. maxAmount)
  return
end

  local edits = {}
  for k, v in pairs(offsets) do
    edits[#edits + 1] = {
      address = addr + k,
      flags = gg.TYPE_DWORD,
      value = (v == "AMT") and amt or v
    }
  end

  gg.setValues(edits)
  gg.toast(emoji .. " " .. _(label) .. ": " .. amt .. " вң…")
end

