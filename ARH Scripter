      "рҹ”№ Ca: Alloc + Other + Anonymous"
    }, nil, _("rangememorymenu"))

    -- вқҢ Jika user cancel вҶ’ tutup menu, tunggu klik GG lagi
    if r == nil then
      return false
    end

    if r == 1 then
      gg.setRanges(gg.REGION_C_ALLOC)
    elseif r == 2 then
      gg.setRanges(gg.REGION_OTHER)
    elseif r == 3 then
      gg.setRanges(gg.REGION_ANONYMOUS)
    elseif r == 4 then
      gg.setRanges(gg.REGION_C_ALLOC | gg.REGION_OTHER)
    elseif r == 5 then
      gg.setRanges(gg.REGION_C_ALLOC | gg.REGION_ANONYMOUS)
    elseif r == 6 then
      gg.setRanges(
        gg.REGION_C_ALLOC |
        gg.REGION_OTHER |
        gg.REGION_ANONYMOUS
      )
    end

    rangesSelected = true
    return true
  end
end

